# 复制此文件为 .env 并填入你的 API Key

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-opus-4-6

# 国产模型（默认通义千问，兼容 OpenAI 格式）
DOMESTIC_API_KEY=xxx
DOMESTIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DOMESTIC_MODEL=qwen-plus

# 默认使用的 provider: openai / claude / domestic
DEFAULT_PROVIDER=openai

# 默认主题
DEFAULT_TOPIC=AI 智能体平台建设方案

# 默认受众
# 可选值：通用受众 | 企业管理层 | 技术团队 | 投资人 | 学生/教育 | 销售团队
DEFAULT_AUDIENCE=通用受众

# 默认页数
# 可选值：8-10页 | 12-15页 | 15-20页 | 20-25页
DEFAULT_PAGES=12-15页

# 输出目录
OUTPUT_DIR=./output
